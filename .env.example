# =============================================================================
#  LLM SRE Sandbox — environment template
# -----------------------------------------------------------------------------
#  Copy to `.env` and fill in values. Variables marked [Phase 1.0] are needed
#  for the initial bring-up; [Phase 1.2] ones are needed before the agent app
#  can produce traces.
#  Never commit `.env` — only this template.
#
#  Reconciled against the codebase in Phase 1.4: every var here is actually
#  read by compose (`${VAR}`), preflight, or the agent app. No dead entries.
# =============================================================================

# --- HuggingFace -------------------------------------------------------- [1.0]
# vLLM downloads the model on first start via huggingface_hub. The token is
# only strictly required for *gated* models (Llama, Gemma, etc.). The default
# Qwen2.5-3B-Instruct-AWQ is ungated, but we still mount the token so the
# Llama fallback in the plan works without re-editing config.
HF_TOKEN=

# --- LiteLLM gateway --------------------------------------------------- [1.0]
# Master key the gateway expects on every request. Used by the agent and by
# anyone hitting the gateway from the host shell. Dev-only — rotate before
# any non-local use.
LITELLM_MASTER_KEY=sk-llm-stack-dev

# --- Langfuse storage -------------------------------------------------- [1.0]
# Postgres password for the Langfuse DB. The DB is internal-only (not bound
# to a host port) but the password still has to be set.
LANGFUSE_DB_PASSWORD=langfuse-dev-pw

# Secrets Langfuse v2 needs for its NextAuth session signing. Generate fresh
# values for any non-toy setup with `openssl rand -hex 32`.
NEXTAUTH_SECRET=replace-me-with-32-bytes-of-random
LANGFUSE_SALT=replace-me-with-32-bytes-of-random

# --- Langfuse API keys ------------------------------------------------- [1.2]
# Public + secret key pair created in the Langfuse UI *after* first launch.
# The agent app reads these directly via the Langfuse SDK (no OTLP — v2
# doesn't expose it). Leave empty for Phase 1.0; populate after running
# `docker compose up langfuse` and clicking through "New Project → API Keys".
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Host-side debugging only ----------------------------------------- [opt]
# When the agent app runs INSIDE compose, these are set by the `environment:`
# block in docker-compose.yaml — the values below are ignored. They only
# matter if you run app/app.py outside compose (e.g. `streamlit run app/app.py`
# against an already-running stack).
OPENAI_API_BASE=http://localhost:4000
MOCK_SERVICES_URL=http://localhost:9000
