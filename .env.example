# =============================================================================
#  LLM SRE Sandbox — environment template
# -----------------------------------------------------------------------------
#  Copy to `.env` and fill in values. Anything marked [Phase 1.0] is required
#  for the initial bring-up; later-phase variables can stay blank for now.
#  Never commit `.env` — only this template.
# =============================================================================

# --- HuggingFace -------------------------------------------------------- [1.0]
# vLLM downloads the model on first start via huggingface_hub. The token is
# only strictly required for *gated* models (Llama, Gemma, etc.). Our default
# Qwen2.5-3B-Instruct-AWQ is ungated, but we still mount the token so the
# Llama fallback in the plan works without re-editing config.
HF_TOKEN=

# --- LiteLLM gateway --------------------------------------------------- [1.0]
# Master key the gateway expects on every request. Used by the app and by
# anyone hitting the gateway from the host. Dev-only — rotate before any
# non-local use.
LITELLM_MASTER_KEY=sk-llm-stack-dev

# --- Langfuse (trace store) -------------------------------------------- [1.0]
# Postgres password for the Langfuse DB. The DB is internal-only (not bound
# to a host port) but the password still needs to be set.
LANGFUSE_DB_PASSWORD=langfuse-dev-pw

# Secrets Langfuse v2 needs for its NextAuth session signing. Generate fresh
# values for any non-toy setup with `openssl rand -hex 32`.
NEXTAUTH_SECRET=replace-me-with-32-bytes-of-random
LANGFUSE_SALT=replace-me-with-32-bytes-of-random

# Public + secret key pair created in the Langfuse UI *after* first launch.
# Phase 1.2 (the agent app) needs these to push OTLP traces. Leave empty for
# Phase 1.0; populate after running `docker compose up langfuse` and clicking
# through "New Project → API Keys".
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Base64 of "${LANGFUSE_PUBLIC_KEY}:${LANGFUSE_SECRET_KEY}" — used as the
# `Authorization: Basic …` header by OpenLLMetry. The preflight script
# computes this automatically if both keys are set.
LANGFUSE_AUTH_B64=

# --- App-layer endpoints (Phase 1.2) ----------------------------------- [1.2]
# These are wired into the app container via compose; values here are only
# used if you run the app outside compose (e.g. local debugging).
OPENAI_API_BASE=http://localhost:4000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3001/api/public/otel
MOCK_SERVICES_URL=http://localhost:9000
