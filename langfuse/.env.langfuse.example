# =============================================================================
#  Langfuse env reference (informational — the live values live in repo-root .env)
# -----------------------------------------------------------------------------
#  This file documents which env vars the Langfuse v3 web + worker containers
#  read. The actual values are pulled from the repo-root `.env` by docker-compose
#  (via the `x-langfuse-env` YAML anchor at the top of docker-compose.yaml).
#  Treat this file as a per-service crib sheet, not a load path.
# =============================================================================

# --- PostgreSQL — primary metadata store ----------------------------------
# Carries over from v2. Holds projects, users, API keys (encrypted), traces
# metadata index. Password comes from $LANGFUSE_DB_PASSWORD.
# DATABASE_URL=postgresql://langfuse:<password>@langfuse-db:5432/langfuse

# --- ClickHouse — event + observation store (new in v3) -------------------
# CLICKHOUSE_URL is the HTTP endpoint used at runtime; CLICKHOUSE_MIGRATION_URL
# is the native-protocol endpoint used by the web container's startup migrator
# to (re)apply the schema before traffic begins.
# CLICKHOUSE_URL=http://langfuse-clickhouse:8123
# CLICKHOUSE_MIGRATION_URL=clickhouse://langfuse-clickhouse:9000
# CLICKHOUSE_USER=langfuse
# CLICKHOUSE_PASSWORD=               # $CLICKHOUSE_PASSWORD in repo .env

# --- Redis — ingest queue between web (enqueue) and worker (dequeue) ------
# Decouples trace-receive from ClickHouse insertion so a slow CH write
# doesn't back-pressure the OTLP endpoint.
# REDIS_HOST=langfuse-redis
# REDIS_PORT=6379
# REDIS_AUTH=                        # $REDIS_PASSWORD in repo .env

# --- Minio (S3-compatible) — staged event batches -------------------------
# Web container writes batches as S3 objects under events/; worker reads them
# back and inserts into ClickHouse. Bucket pre-created via the entrypoint
# trick in docker-compose.yaml (mkdir before `minio server`).
# LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
# LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1     # required; "auto" is not accepted
# LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=       # $MINIO_ROOT_USER
# LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=   # $MINIO_ROOT_PASSWORD
# LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://langfuse-minio:9000
# LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
# LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/

# --- NextAuth (session signing) -------------------------------------------
# The Langfuse web app uses NextAuth for its login. It needs:
#   - the public URL it'll be reached on
#   - a stable secret for signing JWT session cookies
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=                # `openssl rand -hex 32`

# --- Storage encryption -------------------------------------------------
# SALT (carried over from v2): hashes API keys stored at rest.
# ENCRYPTION_KEY (new in v3): 64 hex chars; encrypts sensitive columns
# (integration credentials etc.) at the row level. Once data is written,
# rotating either of these makes prior rows unreadable.
SALT=                           # `openssl rand -hex 32`
ENCRYPTION_KEY=                 # `openssl rand -hex 32`

# --- Telemetry ------------------------------------------------------------
# Langfuse pings home with anonymous usage stats by default. Off for sandbox.
TELEMETRY_ENABLED=false

# --- Project API keys (created via UI on first run) ----------------------
# After you sign in, create a project, go to Settings → API Keys, and paste
# both keys into repo-root `.env`. In Phase 2.1 these are still consumed by
# the agent app's v2-compat callback; in Phase 2.2 they move to the
# otel-collector's basicauth extension config.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
