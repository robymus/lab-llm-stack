# =============================================================================
#  Langfuse env reference (informational — the live values live in repo-root .env)
# -----------------------------------------------------------------------------
#  This file documents which env vars Langfuse v2 reads. The actual values
#  are pulled from the repo-root `.env` by docker-compose. Treat this file
#  as a per-service crib sheet, not a load path.
# =============================================================================

# --- Database --------------------------------------------------------------
# Points at the in-network langfuse-db service. The password component comes
# from $LANGFUSE_DB_PASSWORD; the rest is hard-coded in the compose env block.
# DATABASE_URL=postgresql://langfuse:<password>@langfuse-db:5432/langfuse

# --- NextAuth (session signing) -------------------------------------------
# The Langfuse web app uses NextAuth for its login. It needs:
#   - the public URL it'll be reached on (matters for OAuth redirects, even
#     though we use email login here)
#   - a stable secret for signing JWT session cookies
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=                # `openssl rand -hex 32`

# --- Storage encryption salt ----------------------------------------------
# Encrypts API keys at rest in Postgres. Must NOT change between restarts —
# anything encrypted with the old salt becomes unreadable.
SALT=                           # `openssl rand -hex 32`

# --- Telemetry ------------------------------------------------------------
# Langfuse pings home with anonymous usage stats by default. Off for sandbox.
TELEMETRY_ENABLED=false

# --- Project API keys (created via UI on first run) ----------------------
# After you sign in, create a project, go to Settings → API Keys, and paste
# both keys into repo-root `.env`. The preflight script computes the
# combined base64 used for OTLP authorisation.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_AUTH_B64=$(echo -n "$LANGFUSE_PUBLIC_KEY:$LANGFUSE_SECRET_KEY" | base64 -w0)
