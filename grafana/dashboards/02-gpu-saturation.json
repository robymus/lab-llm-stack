{
  "annotations": { "list": [] },
  "description": "GPU telemetry from DCGM with the gateway p95 latency overlaid. The prefill/decode lesson lives here — watch power and latency in lockstep.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Power draw (W)",
      "description": "Live power vs 30s moving average. LLM serving is bursty: prefill pulls full power, decode idles. The gap between raw and avg is the burstiness.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "DCGM_FI_DEV_POWER_USAGE", "refId": "A", "legendFormat": "power (W)", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "gpu:power_watts_avg30s", "refId": "B", "legendFormat": "30s avg", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "watt", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Temperature (°C)",
      "description": "GPU die temperature. Sustained 80°C+ means thermal throttling is close — look for the SM clock dropping at the same time.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "DCGM_FI_DEV_GPU_TEMP", "refId": "A", "legendFormat": "GPU temp", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Frame-buffer (VRAM) used",
      "description": "VRAM consumption. vLLM grabs --gpu-memory-utilization fraction at startup (you'll see this jump immediately, then stay roughly flat — the slab is managed internally).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "DCGM_FI_DEV_FB_USED * 1024 * 1024", "refId": "A", "legendFormat": "used", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "DCGM_FI_DEV_FB_FREE * 1024 * 1024", "refId": "B", "legendFormat": "free", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Clocks (MHz)",
      "description": "SM (compute) and memory clocks. If SM clock drops sharply mid-run, suspect thermal throttling (check the temp panel) or power capping.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "DCGM_FI_DEV_SM_CLOCK", "refId": "A", "legendFormat": "SM clock", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "DCGM_FI_DEV_MEM_CLOCK", "refId": "B", "legendFormat": "mem clock", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rotmhz", "custom": { "drawStyle": "line", "lineWidth": 2 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GPU power ↔ LLM p95 latency (shared time axis)",
      "description": "The correlation lesson. Power spikes during prefill (TTFT-dominated requests); latency p95 climbs at the same wall-clock time. Watch them tick together.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "targets": [
        { "expr": "DCGM_FI_DEV_POWER_USAGE", "refId": "A", "legendFormat": "GPU power (W)", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "llm:request_latency_p95_seconds", "refId": "B", "legendFormat": "p95 latency (s)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "axisPlacement": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "GPU power (W)" }, "properties": [{ "id": "unit", "value": "watt" }, { "id": "custom.axisPlacement", "value": "left" }] },
          { "matcher": { "id": "byName", "options": "p95 latency (s)" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["llm-stack", "phase-1.1"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "GPU Saturation",
  "uid": "gpu-saturation",
  "version": 1,
  "weekStart": ""
}
